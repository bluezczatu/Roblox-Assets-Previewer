{
  "name": "roblox-asset-previewer",
  "icon": "icon.png",
  "displayName": "Roblox Asset Previewer",
  "description": "The Roblox Asset Previewer for VS Code takes the mystery out of asset IDs. Get instant visual previews, author details, and asset types displayed inline with your scripts. Develop faster, debug smarter.",
  "version": "1.0.2",
  "publisher": "bluezczatu",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "RobloxAssetPreviewer.download",
        "title": "Roblox Asset Preview: Download Asset"
      }
    ],
    "configuration": {
      "title": "Roblox Asset Previewer",
      "properties": {
        "RobloxAssetPreviewer.imageSize": {
          "type": "number",
          "default": 256,
          "description": "Preview Size (128–512 px)"
        }
      }
    }
  }
}
